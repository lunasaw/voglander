digraph VoglanderSystemArchitecture {
  graph [
    rankdir=LR,
    bgcolor="#0B1020",
    pad="0.55",
    nodesep="0.65",
    ranksep="0.9",
    splines=ortho,
    outputorder=edgesfirst,
    fontname="PingFang SC",
    label="Voglander 当前系统架构",
    labelloc=t,
    labeljust=c,
    fontsize=26,
    fontcolor="#F8FAFC"
  ];

  node [
    shape=rect,
    style="rounded,filled",
    fontname="PingFang SC",
    fontsize=13,
    color="#334155",
    penwidth=1.4,
    margin="0.14,0.10",
    fontcolor="#E5E7EB"
  ];

  edge [
    color="#94A3B8",
    fontname="PingFang SC",
    fontsize=11,
    fontcolor="#CBD5E1",
    arrowsize=0.75,
    penwidth=1.8
  ];

  subgraph cluster_external {
    label="接入端 / 外部系统";
    labelloc=t;
    labeljust=l;
    fontcolor="#FDE68A";
    color="#334155";
    fillcolor="#111827";
    style="rounded,filled";
    penwidth=1.2;

    browser [label="Web Console\nvue-vben-admin / Protocol Lab", fillcolor="#0F766E", color="#14B8A6"];
    gb_device [label="IPC / NVR / 下级平台\nGB28181 SIP + RTP", fillcolor="#92400E", color="#F59E0B"];
    zlm [label="ZLMediaKit\nHTTP API / Hook / RTP", fillcolor="#1D4ED8", color="#60A5FA"];
  }

  subgraph cluster_app {
    label="Voglander 后端应用（Spring Boot 3.5.3 / Java 17）";
    labelloc=t;
    labeljust=l;
    fontcolor="#BAE6FD";
    color="#334155";
    fillcolor="#111827";
    style="rounded,filled";
    penwidth=1.2;

    web [label="voglander-web\nController / Filter / Interceptor\nSSE / Internal API / ApplicationWeb", fillcolor="#075985", color="#38BDF8"];
    service [label="voglander-service\nMediaPlayService / DeviceAgreementService\nSSE EventBus / Stream Biz / Register", fillcolor="#166534", color="#4ADE80"];
    manager [label="voglander-manager\nManager 模板 / Service Impl / Assembler\nEvent Shard / Protocol Route / Node Route", fillcolor="#7C2D12", color="#FB923C"];
    integration [label="voglander-integration\nGB28181 Notifier + Command + Supplier\nZLM Wrapper + Hook / EasyExcel", fillcolor="#831843", color="#F472B6"];
    repository [label="voglander-repository\nDO / Mapper / RedisCache\n@Cached / RedisLock", fillcolor="#312E81", color="#818CF8"];
    client_common [label="voglander-client + common\n接口契约 / DTO-QO / 常量枚举\nAjaxResult / ServiceException", fillcolor="#334155", color="#94A3B8"];
  }

  subgraph cluster_infra {
    label="基础设施";
    labelloc=t;
    labeljust=l;
    fontcolor="#D1D5DB";
    color="#334155";
    fillcolor="#111827";
    style="rounded,filled";
    penwidth=1.2;

    db [label="MySQL / SQLite\n业务表 + 会话 + 菜单权限", fillcolor="#1F2937", color="#64748B"];
    redis [label="Redis\n缓存 / 分布式锁 / PubSub\n设备节点路由 / Live Registry", fillcolor="#1F2937", color="#64748B"];
    skywalking [label="SkyWalking\n链路追踪 / 日志关联", fillcolor="#1F2937", color="#64748B"];
  }

  browser -> web [label="REST / SSE / JWT", color="#22D3EE"];
  web -> service [label="业务编排", color="#86EFAC"];
  web -> manager [label="简单 CRUD / DTO", color="#FDBA74"];
  web -> integration [label="ZLM Hook/API 入口", color="#F9A8D4"];

  service -> manager [label="领域服务调用 Manager", color="#BBF7D0"];
  service -> integration [label="协议命令 / ZLM 能力", color="#F9A8D4"];
  integration -> manager [label="回调落库 / 状态同步", color="#FDBA74"];
  manager -> repository [label="DTO ↔ DO / IService", color="#A5B4FC"];
  repository -> db [label="MyBatis-Plus", color="#CBD5E1"];
  repository -> redis [label="@Cached / Lock", color="#CBD5E1"];
  service -> redis [label="SSE PubSub / Live Registry", color="#CBD5E1"];
  manager -> redis [label="节点亲和路由 / 延迟双删", color="#CBD5E1"];

  client_common -> web [label="Req/VO/常量", style=dashed, color="#64748B"];
  client_common -> service [label="Service 契约", style=dashed, color="#64748B"];
  client_common -> manager [label="DTO / 事件模型", style=dashed, color="#64748B"];
  client_common -> integration [label="ResultDTO / Event", style=dashed, color="#64748B"];

  gb_device -> integration [label="REGISTER / NOTIFY / RESPONSE", color="#F59E0B"];
  integration -> gb_device [label="MESSAGE / INVITE / BYE", color="#F59E0B"];
  gb_device -> zlm [label="RTP 推流", color="#60A5FA"];
  integration -> zlm [label="HTTP API", color="#60A5FA"];
  zlm -> integration [label="Hook 回调", color="#60A5FA"];

  web -> skywalking [label="Trace", style=dotted, color="#64748B"];
  service -> skywalking [label="Trace", style=dotted, color="#64748B"];
  integration -> skywalking [label="SIP/ZLM Trace", style=dotted, color="#64748B"];
}
