        deleted_at,delete_reason,failure_code,failure_message,version</sql>
    <sql id="InsertValues">#{asset.createTime},#{asset.updateTime},#{asset.assetId},#{asset.assetName},#{asset.status},
        #{asset.storageProvider},#{asset.storageBucket},#{asset.storageKey},#{asset.storageNodeId},#{asset.contentType},
        #{asset.imageFormat},#{asset.fileSize},#{asset.width},#{asset.height},#{asset.checksumAlgorithm},#{asset.checksum},
        #{asset.capturedAt},#{asset.ingestedAt},#{asset.ownerType},#{asset.ownerId},#{asset.organizationId},
        #{asset.idempotencyKey},#{asset.retentionPolicy},#{asset.expiresAt},#{asset.deletedAt},#{asset.deleteReason},
        #{asset.failureCode},#{asset.failureMessage},#{asset.version}</sql>
    <insert id="insertIfAbsent" databaseId="sqlite" useGeneratedKeys="true" keyProperty="asset.id">
        INSERT OR IGNORE INTO tb_image_asset (<include refid="InsertColumns"/>) VALUES (<include refid="InsertValues"/>)
    </insert>
    <insert id="insertIfAbsent" databaseId="mysql" useGeneratedKeys="true" keyProperty="asset.id">
        INSERT IGNORE INTO tb_image_asset (<include refid="InsertColumns"/>) VALUES (<include refid="InsertValues"/>)
    </insert>
    <insert id="insertIfAbsent" databaseId="postgresql" useGeneratedKeys="true" keyProperty="asset.id">
        INSERT INTO tb_image_asset (<include refid="InsertColumns"/>) VALUES (<include refid="InsertValues"/>) ON CONFLICT DO NOTHING
    </insert>
    <select id="selectByAssetId" resultMap="BaseResultMap">SELECT <include refid="Columns"/> FROM tb_image_asset WHERE asset_id=#{assetId} LIMIT 1</select>
    <select id="selectEnrichedByAssetId" resultMap="EnrichedResultMap">
        SELECT <include refid="EnrichedColumns"/> FROM tb_image_asset a
        LEFT JOIN tb_image_asset_source s ON s.asset_id=a.asset_id
        WHERE a.asset_id=#{assetId} LIMIT 1
    </select>
    <select id="selectByIdempotency" resultMap="BaseResultMap">SELECT <include refid="Columns"/> FROM tb_image_asset
        WHERE owner_type=#{ownerType} AND owner_id=#{ownerId} AND idempotency_key=#{idempotencyKey} LIMIT 1</select>
    <select id="selectPageByCondition" databaseId="mysql" resultMap="BaseResultMap">
        SELECT DISTINCT <include refid="QualifiedColumns"/> FROM tb_image_asset a
        LEFT JOIN tb_image_asset_source s ON s.asset_id=a.asset_id
        WHERE 1=1
        <if test="status == null or status == ''">AND a.status &lt;&gt; 'DELETED'</if>
        <if test="ownerType != null and ownerType != ''">AND a.owner_type=#{ownerType}</if>
        <if test="ownerId != null and ownerId != ''">AND a.owner_id=#{ownerId}</if>
        <if test="assetId != null and assetId != ''">AND a.asset_id=#{assetId}</if>
        <if test="assetName != null and assetName != ''">AND a.asset_name LIKE CONCAT('%',#{assetName},'%')</if>
        <if test="status != null and status != ''">AND a.status=#{status}</if>
        <if test="sourceType != null and sourceType != ''">AND s.source_type=#{sourceType}</if>
        <if test="sourceTaskId != null and sourceTaskId != ''">AND s.source_task_id=#{sourceTaskId}</if>
        <if test="sourceExecutionId != null and sourceExecutionId != ''">AND s.source_execution_id=#{sourceExecutionId}</if>
        <if test="deviceId != null and deviceId != '' and channelId != null and channelId != ''">AND s.source_entity_id=CONCAT(#{deviceId},':',#{channelId})</if>
        <if test="deviceId != null and deviceId != '' and (channelId == null or channelId == '')">AND s.source_entity_id LIKE CONCAT(#{deviceId},':%')</if>
        <if test="channelId != null and channelId != '' and (deviceId == null or deviceId == '')">AND s.source_entity_id LIKE CONCAT('%:',#{channelId})</if>
        <if test="capturedStart != null">AND a.captured_at &gt;=#{capturedStart}</if>
        <if test="capturedEnd != null">AND a.captured_at &lt;=#{capturedEnd}</if>
        ORDER BY a.captured_at DESC,a.asset_id DESC
    </select>
    <select id="selectPageByCondition" databaseId="sqlite" resultMap="BaseResultMap">
        SELECT DISTINCT <include refid="QualifiedColumns"/> FROM tb_image_asset a
        LEFT JOIN tb_image_asset_source s ON s.asset_id=a.asset_id
        WHERE 1=1
        <if test="status == null or status == ''">AND a.status &lt;&gt; 'DELETED'</if>
        <if test="ownerType != null and ownerType != ''">AND a.owner_type=#{ownerType}</if>
        <if test="ownerId != null and ownerId != ''">AND a.owner_id=#{ownerId}</if>
        <if test="assetId != null and assetId != ''">AND a.asset_id=#{assetId}</if>
        <if test="assetName != null and assetName != ''">AND a.asset_name LIKE '%' || #{assetName} || '%'</if>
        <if test="status != null and status != ''">AND a.status=#{status}</if>
        <if test="sourceType != null and sourceType != ''">AND s.source_type=#{sourceType}</if>
        <if test="sourceTaskId != null and sourceTaskId != ''">AND s.source_task_id=#{sourceTaskId}</if>
        <if test="sourceExecutionId != null and sourceExecutionId != ''">AND s.source_execution_id=#{sourceExecutionId}</if>
        <if test="deviceId != null and deviceId != '' and channelId != null and channelId != ''">AND s.source_entity_id=(#{deviceId} || ':' || #{channelId})</if>
        <if test="deviceId != null and deviceId != '' and (channelId == null or channelId == '')">AND s.source_entity_id LIKE #{deviceId} || ':%'</if>
        <if test="channelId != null and channelId != '' and (deviceId == null or deviceId == '')">AND s.source_entity_id LIKE '%:' || #{channelId}</if>
        <if test="capturedStart != null">AND a.captured_at &gt;=#{capturedStart}</if>
        <if test="capturedEnd != null">AND a.captured_at &lt;=#{capturedEnd}</if>
        ORDER BY a.captured_at DESC,a.asset_id DESC
    </select>
    <select id="selectPageByCondition" databaseId="postgresql" resultMap="BaseResultMap">
        SELECT DISTINCT <include refid="QualifiedColumns"/> FROM tb_image_asset a
        LEFT JOIN tb_image_asset_source s ON s.asset_id=a.asset_id
        WHERE 1=1
        <if test="status == null or status == ''">AND a.status &lt;&gt; 'DELETED'</if>
        <if test="ownerType != null and ownerType != ''">AND a.owner_type=#{ownerType}</if>
        <if test="ownerId != null and ownerId != ''">AND a.owner_id=#{ownerId}</if>
        <if test="assetId != null and assetId != ''">AND a.asset_id=#{assetId}</if>
        <if test="assetName != null and assetName != ''">AND a.asset_name LIKE '%' || #{assetName} || '%'</if>
        <if test="status != null and status != ''">AND a.status=#{status}</if>
        <if test="sourceType != null and sourceType != ''">AND s.source_type=#{sourceType}</if>
        <if test="sourceTaskId != null and sourceTaskId != ''">AND s.source_task_id=#{sourceTaskId}</if>
        <if test="sourceExecutionId != null and sourceExecutionId != ''">AND s.source_execution_id=#{sourceExecutionId}</if>
        <if test="deviceId != null and deviceId != '' and channelId != null and channelId != ''">AND s.source_entity_id=(#{deviceId} || ':' || #{channelId})</if>
        <if test="deviceId != null and deviceId != '' and (channelId == null or channelId == '')">AND s.source_entity_id LIKE #{deviceId} || ':%'</if>
        <if test="channelId != null and channelId != '' and (deviceId == null or deviceId == '')">AND s.source_entity_id LIKE '%:' || #{channelId}</if>
        <if test="capturedStart != null">AND a.captured_at &gt;=#{capturedStart}</if>
        <if test="capturedEnd != null">AND a.captured_at &lt;=#{capturedEnd}</if>
        ORDER BY a.captured_at DESC,a.asset_id DESC
    </select>
    <select id="selectEnrichedPageByCondition" resultMap="EnrichedResultMap">
        <bind name="assetNameLike" value="assetName == null ? null : '%' + assetName + '%'"/>
        <bind name="sourceEntityId" value="deviceId == null || channelId == null ? null : deviceId + ':' + channelId"/>
        <bind name="devicePrefix" value="deviceId == null ? null : deviceId + ':%'"/>
        <bind name="channelSuffix" value="channelId == null ? null : '%:' + channelId"/>
        SELECT <include refid="EnrichedColumns"/> FROM tb_image_asset a
        LEFT JOIN tb_image_asset_source s ON s.asset_id=a.asset_id
        WHERE 1=1
        <if test="status == null or status == ''">AND a.status &lt;&gt; 'DELETED'</if>
        <if test="ownerType != null and ownerType != ''">AND a.owner_type=#{ownerType}</if>
        <if test="ownerId != null and ownerId != ''">AND a.owner_id=#{ownerId}</if>
        <if test="assetId != null and assetId != ''">AND a.asset_id=#{assetId}</if>
        <if test="assetName != null and assetName != ''">AND a.asset_name LIKE #{assetNameLike}</if>
        <if test="status != null and status != ''">AND a.status=#{status}</if>
        <if test="sourceType != null and sourceType != ''">AND s.source_type=#{sourceType}</if>
        <if test="sourceTaskId != null and sourceTaskId != ''">AND s.source_task_id=#{sourceTaskId}</if>
        <if test="sourceExecutionId != null and sourceExecutionId != ''">AND s.source_execution_id=#{sourceExecutionId}</if>
        <if test="deviceId != null and deviceId != '' and channelId != null and channelId != ''">AND s.source_entity_id=#{sourceEntityId}</if>
        <if test="deviceId != null and deviceId != '' and (channelId == null or channelId == '')">AND s.source_entity_id LIKE #{devicePrefix}</if>
        <if test="channelId != null and channelId != '' and (deviceId == null or deviceId == '')">AND s.source_entity_id LIKE #{channelSuffix}</if>
        <if test="capturedStart != null">AND a.captured_at &gt;=#{capturedStart}</if>
        <if test="capturedEnd != null">AND a.captured_at &lt;=#{capturedEnd}</if>
        ORDER BY a.captured_at DESC,a.asset_id DESC
    </select>
    <select id="countVisible" resultType="long">SELECT COUNT(*) FROM tb_image_asset
        WHERE 1=1
        <if test="ownerType != null and ownerType != ''">AND owner_type=#{ownerType}</if>
        <if test="ownerId != null and ownerId != ''">AND owner_id=#{ownerId}</if>
        <if test="status != null and status != ''">AND status=#{status}</if>
        <if test="createdAfter != null">AND create_time &gt;=#{createdAfter}</if>
    </select>
    <update id="markDeleting">UPDATE tb_image_asset SET status='DELETING',update_time=#{updateTime},version=version+1
        WHERE asset_id=#{assetId} AND version=#{version} AND status IN ('AVAILABLE','DELETE_FAILED')</update>
    <update id="markDeleted">UPDATE tb_image_asset SET status='DELETED',deleted_at=#{deletedAt},update_time=#{updateTime},
        failure_code=NULL,failure_message=NULL,version=version+1 WHERE asset_id=#{assetId} AND version=#{version} AND status='DELETING'</update>
    <update id="markDeleteFailed">UPDATE tb_image_asset SET status='DELETE_FAILED',failure_code=#{failureCode},
        failure_message=#{failureMessage},update_time=#{updateTime},version=version+1 WHERE asset_id=#{assetId} AND version=#{version} AND status='DELETING'</update>
</mapper>
